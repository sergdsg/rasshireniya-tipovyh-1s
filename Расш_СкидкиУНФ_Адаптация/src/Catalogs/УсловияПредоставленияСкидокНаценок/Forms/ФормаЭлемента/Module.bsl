
#Область ОбработчикиСобытийФормы
	
	
&НаСервере
Процедура Скидки_ПриСозданииНаСервереПосле(Отказ, СтандартнаяОбработка)
	
	ИмяКоманды = "Ск_ДобавитьНоменклатуруСХарактеристиками";
	Команда = Команды.Добавить(ИмяКоманды);
	Команда.Действие = ИмяКоманды;
	Команда.ИзменяетСохраняемыеДанные = Истина;
	Команда.Заголовок = "Добавить номенклатуру с характеристиками";
	
	Кнопка = Элементы.Добавить(ИмяКоманды,Тип("КнопкаФормы"),Элементы.ОтборПродажПоНоменклатуре.КоманднаяПанель);
	Кнопка.ИмяКоманды = ИмяКоманды;
	
КонецПроцедуры
	
	
#КонецОбласти

#Область ОбработчикиКомандФормы
		
	&НаКлиенте
	Процедура Ск_ДобавитьНоменклатуруСХарактеристиками(Команда)
		ПараметрыОткрытия = Новый Структура("РежимВыбора, МножественныйВыбор, ЗакрыватьПриВыборе", Истина, Истина, Истина);
		
		ОповещениеОЗакрытии = Новый ОписаниеОповещения("Ск_ДобавитьНоменклатуруСХарактеристикамиЗавершение", ЭтотОбъект);
		ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыОткрытия, ЭтотОбъект,,,, ОповещениеОЗакрытии);
		
	КонецПроцедуры
	
#КонецОбласти


#Область СлужебныеПроцедурыИФункции

// Обработчик завершения выбора номенклатуры с характеристиками.
//
// Параметры:
//   РезультатЗакрытия - Массив из СправочникСсылка.Номенклатура - список номенклатуры для добавления.
//   ДополнительныеПараметры - Произвольный - дополнительные параметры, переданные при открытии формы.
//
	&НаКлиенте
	Процедура Ск_ДобавитьНоменклатуруСХарактеристикамиЗавершение(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
		
		Если ЗначениеЗаполнено(РезультатЗакрытия) Тогда
			ДобавитьНоменклатуруСХарактеристикамиНасервере(РезультатЗакрытия);	
			Объект.Наименование = СформироватьАвтоНаименованиеНаКлиенте();
		КонецЕсли;
	
	КонецПроцедуры
	
	
// Добавляет номенклатуру с характеристиками в табличную часть "ОтборПродажПоНоменклатуре" на сервере.
//
// Параметры:
//   СписокТоваров - Массив из СправочникСсылка.Номенклатура - список номенклатуры для добавления.
//
	&НаСервере
	Процедура ДобавитьНоменклатуруСХарактеристикамиНасервере(СписокТоваров)
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Номенклатура.Ссылка КАК Ссылка,
		|	Номенклатура.КатегорияНоменклатуры КАК КатегорияНоменклатуры,
		|	Номенклатура.ИспользоватьХарактеристики КАК ИспользоватьХарактеристики
		|ПОМЕСТИТЬ вт_Номенклатура
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка В(&СписокТоваров)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	вт_Номенклатура.Ссылка КАК Номенклатура,
		|	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
		|	ИСТИНА КАК ХарактеристикиИспользуются
		|ИЗ
		|	вт_Номенклатура КАК вт_Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|		ПО вт_Номенклатура.Ссылка = ХарактеристикиНоменклатуры.Владелец
		|			И (НЕ ХарактеристикиНоменклатуры.ПометкаУдаления)
		|			И (НЕ ХарактеристикиНоменклатуры.Недействителен)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	вт_Номенклатура.Ссылка,
		|	ХарактеристикиНоменклатуры.Ссылка,
		|	ИСТИНА
		|ИЗ
		|	вт_Номенклатура КАК вт_Номенклатура
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|		ПО вт_Номенклатура.КатегорияНоменклатуры = ХарактеристикиНоменклатуры.Владелец
		|			И (НЕ ХарактеристикиНоменклатуры.ПометкаУдаления)
		|			И (НЕ ХарактеристикиНоменклатуры.Недействителен)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	вт_Номенклатура.Ссылка,
		|	ЗНАЧЕНИЕ(Справочник.ХарактеристикиНоменклатуры.ПустаяСсылка),
		|	ЛОЖЬ
		|ИЗ
		|	вт_Номенклатура КАК вт_Номенклатура
		|ГДЕ
		|	НЕ вт_Номенклатура.ИспользоватьХарактеристики
		|
		|УПОРЯДОЧИТЬ ПО
		|	Номенклатура,
		|	Характеристика
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("СписокТоваров", СписокТоваров);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		ПараметрыПоиска = Новый Структура("Номенклатура, Характеристика", Выборка.Номенклатура, Выборка.Характеристика);
		НайденныеСстроки = Объект.ОтборПродажПоНоменклатуре.НайтиСтроки(ПараметрыПоиска);
		
		Если НайденныеСстроки.Количество() = 0 Тогда
			
		НоваяСтрока = Объект.ОтборПродажПоНоменклатуре.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока,Выборка);	
		Элементы.ОтборПродажПоНоменклатуре.ТекущаяСтрока = НоваяСтрока.ПолучитьИдентификатор();
		
		КонецЕсли;
	
	КонецЦикла;
	

КонецПроцедуры	
#КонецОбласти